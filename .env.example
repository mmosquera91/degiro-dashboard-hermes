BROKR_AUTH_TOKEN=dev-secret-change-in-production
# Session auth — change both in production
APP_PASSWORD=change-me-in-production
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Set to false for HTTP (local/internal deployments).
# With true (default), browsers silently drop cookies over HTTP → login broken.
COOKIE_SECURE=false

# Indexa Capital API
INDEXA_API_TOKEN=your-indexa-api-token-here
